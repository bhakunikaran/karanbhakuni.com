{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Pages }}
  {{- $priority := 0.6 }}{{ $freq := "monthly" }}
  {{- if .IsHome }}{{ $priority = 1.0 }}{{ $freq = "daily" }}
  {{- else if eq .Section "posts" }}{{ if .IsPage }}{{ $priority = 0.8 }}{{ $freq = "monthly" }}{{ else }}{{ $priority = 0.7 }}{{ $freq = "weekly" }}{{ end }}
  {{- end }}
  <url>
    <loc>{{ .Permalink }}</loc>{{ if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>{{ end }}
    <changefreq>{{ $freq }}</changefreq>
    <priority>{{ $priority }}</priority>
  </url>
  {{- end }}
</urlset>
